rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // 공통 유틸리티 함수
    // ==========================================
    
    // 사용자 인증 확인
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // 사용자 본인 확인
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // 데이터 타입 및 크기 검증 함수
    function isValidString(data, field, min, max) {
      return data[field] is string && 
             data[field].size() >= min && 
             data[field].size() <= max;
    }

    // ==========================================
    // 컬렉션별 보안 규칙
    // ==========================================
    
    // === 사용자 프로필 컬렉션 ===
    match /users/{userId} {
      // 본인만 전체 프로필 읽기 및 수정 가능
      allow read, write: if isOwner(userId);
    }
    
    // [New] 검색 전역 공개 프로필 (이메일 제외)
    match /publicProfiles/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }
    
    // === 메모 컬렉션 ===
    match /memos/{memoId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        (resource.data.sharedWithUids != null && request.auth.uid in resource.data.sharedWithUids)
      );
      
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid &&
        isValidString(request.resource.data, 'title', 1, 100) &&
        isValidString(request.resource.data, 'content', 0, 10000);
      
      allow update: if isAuthenticated() && (
        // 소유자 수정
        (resource.data.userId == request.auth.uid && 
         isValidString(request.resource.data, 'title', 1, 100)) ||
        // 공유 받은 사용자의 수정 (단순화: sharedWithUids 멤버십 확인)
        (resource.data.sharedWithUids != null && request.auth.uid in resource.data.sharedWithUids &&
         request.resource.data.userId == resource.data.userId)
      );
      
      allow delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        (resource.data.sharedWithUids != null && request.auth.uid in resource.data.sharedWithUids)
      );
    }
    
    // === 알림 컬렉션 ===
    match /notifications/{notificationId} {
      // 읽기: 수신자 본인만
      allow read: if isAuthenticated() && 
        resource.data.receiverId == request.auth.uid;
      
      // 생성: 보안 강화된 생성 조건
      allow create: if isAuthenticated() && 
        // 1. 발신자 본인 확인
        request.resource.data.senderId == request.auth.uid &&
        // 2. 해당 메모의 소유자이거나 관리 권한이 있는 경우에만 알림 생성 가능 (Abuse 방지)
        get(/databases/$(database)/documents/memos/$(request.resource.data.memoId)).data.userId == request.auth.uid;
      
      // 업데이트: 읽음 처리만 허용
      allow update: if isAuthenticated() && 
        resource.data.receiverId == request.auth.uid &&
        request.resource.data.isRead == true;
      
      allow delete: if isAuthenticated() && 
        resource.data.receiverId == request.auth.uid;
    }
    
    // === 카테고리 컬렉션 ===
    match /categories/{categoryId} {
      // 읽기: 인증된 사용자라면 허용 (템플릿과 동일한 방식)
      allow read: if isAuthenticated();
      
      // 생성/수정/삭제: 본인 데이터만 가능
      allow write: if isAuthenticated() && (
        request.resource == null || request.resource.data.userId == request.auth.uid
      ) && (
        resource == null || resource.data.userId == request.auth.uid
      );
    }
    
    // === 템플릿 컬렉션 ===
    match /templates/{templateId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        resource.data.isPublic == true
      );
      
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid &&
        isValidString(request.resource.data, 'title', 1, 100);
        
      allow update, delete: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
    }
    
    // === 기본 거부 규칙 ===
    match /{document=**} {
      allow read, write: if false;
    }
  }
} 